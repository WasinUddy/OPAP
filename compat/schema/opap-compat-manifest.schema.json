{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opap.local/schema/opap-compat-manifest-v1.json",
  "title": "OPAP OSCAR differential compatibility manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "oracle", "producer", "fixture", "machine", "sessions"],
  "properties": {
    "schema_version": { "const": "opap-oscar-compat/v1" },
    "oracle": { "$ref": "#/$defs/oracle" },
    "producer": { "$ref": "#/$defs/producer" },
    "fixture": { "$ref": "#/$defs/fixture" },
    "machine": { "$ref": "#/$defs/machine" },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/session" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "fixture": {
            "properties": { "synthetic": { "const": false } },
            "required": ["synthetic"]
          }
        }
      },
      "then": {
        "properties": {
          "producer": {
            "properties": {
              "adapter_attestation": { "const": "verified_clean_tree" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitRevision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "canonicalIdentifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "jsonSafeUnsigned": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "jsonSafePositive": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "jsonSafeSigned": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "resmedFileKind": {
      "enum": ["eve", "brp", "pld"]
    },
    "utcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "localTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}$"
    },
    "nullableUtcOffset": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": -64800,
          "maximum": 64800
        },
        { "type": "null" }
      ]
    },
    "canonicalEdfDecimal": {
      "type": "string",
      "maxLength": 8,
      "pattern": "^(?!-0(\\.0*)?$)-?(0|[1-9][0-9]*)(\\.[0-9]*[1-9])?$"
    },
    "canonicalPositiveEdfDecimal": {
      "type": "string",
      "maxLength": 8,
      "pattern": "^(0\\.[0-9]*[1-9]|[1-9][0-9]*(\\.[0-9]*[1-9])?)$"
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repository", "revision", "export_schema_version"],
      "properties": {
        "name": { "const": "OSCAR" },
        "repository": { "const": "https://gitlab.com/CrimsonNape/OSCAR-code" },
        "revision": { "const": "64c5e90a26f91fb15868bcfcccde0c1e1522ac86" },
        "export_schema_version": { "const": "opap-oscar-oracle/v1" }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "name",
        "source_revision",
        "adapter_attestation",
        "adapter_repository",
        "adapter_revision",
        "adapter_tree_sha256",
        "adapter_conformance_sha256",
        "adapter_clean"
      ],
      "oneOf": [
        {
          "properties": {
            "role": { "const": "oracle" },
            "name": { "const": "OSCAR" },
            "source_revision": { "const": "64c5e90a26f91fb15868bcfcccde0c1e1522ac86" }
          }
        },
        {
          "properties": {
            "role": { "const": "subject" },
            "name": { "const": "OPAP" },
            "source_revision": { "$ref": "#/$defs/gitRevision" }
          }
        }
      ],
      "properties": {
        "role": { "enum": ["oracle", "subject"] },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "source_revision": { "$ref": "#/$defs/gitRevision" },
        "adapter_attestation": { "enum": ["synthetic_fixture_only", "verified_clean_tree"] },
        "adapter_repository": { "type": "string", "pattern": "^https://" },
        "adapter_revision": { "$ref": "#/$defs/gitRevision" },
        "adapter_tree_sha256": { "$ref": "#/$defs/sha256" },
        "adapter_conformance_sha256": { "$ref": "#/$defs/sha256" },
        "adapter_clean": { "const": true }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "source_sha256", "synthetic"],
      "properties": {
        "case_id": { "$ref": "#/$defs/canonicalIdentifier" },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "synthetic": { "type": "boolean" }
      }
    },
    "machine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manufacturer", "model", "model_number", "serial_number", "firmware", "sha256"],
      "properties": {
        "manufacturer": { "$ref": "#/$defs/nonEmptyString" },
        "model": { "$ref": "#/$defs/nonEmptyString" },
        "model_number": { "type": "string" },
        "serial_number": { "$ref": "#/$defs/nonEmptyString" },
        "firmware": { "type": "string" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "source_id_sha256",
        "source_sha256",
        "sha256",
        "time",
        "slices",
        "summary",
        "settings",
        "events",
        "waveforms"
      ],
      "properties": {
        "session_id": { "$ref": "#/$defs/canonicalIdentifier" },
        "source_id_sha256": { "$ref": "#/$defs/sha256" },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "time": { "$ref": "#/$defs/sessionTime" },
        "slices": { "$ref": "#/$defs/slices" },
        "summary": { "$ref": "#/$defs/summary" },
        "settings": { "$ref": "#/$defs/settings" },
        "events": { "$ref": "#/$defs/events" },
        "waveforms": { "$ref": "#/$defs/waveforms" }
      }
    },
    "sessionTime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_utc",
        "end_utc",
        "start_local",
        "end_local",
        "start_utc_offset_seconds",
        "end_utc_offset_seconds",
        "timezone_basis",
        "start_clock_correction_milliseconds",
        "end_clock_correction_milliseconds"
      ],
      "properties": {
        "start_utc": { "$ref": "#/$defs/utcTimestamp" },
        "end_utc": { "$ref": "#/$defs/utcTimestamp" },
        "start_local": { "$ref": "#/$defs/localTimestamp" },
        "end_local": { "$ref": "#/$defs/localTimestamp" },
        "start_utc_offset_seconds": { "$ref": "#/$defs/nullableUtcOffset" },
        "end_utc_offset_seconds": { "$ref": "#/$defs/nullableUtcOffset" },
        "timezone_basis": { "const": "source_endpoint_metadata" },
        "start_clock_correction_milliseconds": { "$ref": "#/$defs/jsonSafeSigned" },
        "end_clock_correction_milliseconds": { "$ref": "#/$defs/jsonSafeSigned" }
      }
    },
    "slices": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "sha256", "items"],
      "properties": {
        "count": { "$ref": "#/$defs/jsonSafePositive" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sessionSlice" }
        }
      }
    },
    "sessionSlice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "source_id_sha256", "status", "start_offset_milliseconds", "end_offset_milliseconds"],
      "properties": {
        "sequence": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "source_id_sha256": { "$ref": "#/$defs/sha256" },
        "status": { "enum": ["mask_on", "mask_off", "equipment_off"] },
        "start_offset_milliseconds": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "end_offset_milliseconds": { "$ref": "#/$defs/jsonSafeUnsigned" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usage_milliseconds", "metric_count", "source_sha256", "metrics"],
      "properties": {
        "usage_milliseconds": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "metric_count": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/summaryMetric" }
        }
      }
    },
    "summaryMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value", "unit"],
      "properties": {
        "key": { "$ref": "#/$defs/canonicalIdentifier" },
        "value": { "$ref": "#/$defs/nullableNumber" },
        "unit": { "type": "string" }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "sha256", "items"],
      "properties": {
        "count": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/setting" }
        }
      }
    },
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value", "unit"],
      "properties": {
        "key": { "$ref": "#/$defs/canonicalIdentifier" },
        "value": { "$ref": "#/$defs/settingValue" },
        "unit": { "type": "string" }
      }
    },
    "settingValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "number" },
            "value": { "type": "number" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "integer" },
            "value": { "$ref": "#/$defs/jsonSafeSigned" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "boolean" },
            "value": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": { "const": "text" },
            "value": { "type": "string" }
          }
        }
      ]
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_count", "sha256", "channels"],
      "properties": {
        "channel_count": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "channels": {
          "type": "array",
          "items": { "$ref": "#/$defs/eventChannel" }
        }
      }
    },
    "eventChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "source_file_kind", "unit", "count", "sha256", "items"],
      "properties": {
        "channel_id": { "$ref": "#/$defs/canonicalIdentifier" },
        "source_file_kind": { "const": "eve" },
        "unit": { "type": "string" },
        "count": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/event" }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "source_id_sha256", "offset_milliseconds", "duration_milliseconds", "value"],
      "properties": {
        "sequence": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "source_id_sha256": { "$ref": "#/$defs/sha256" },
        "offset_milliseconds": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "duration_milliseconds": {
          "oneOf": [
            { "$ref": "#/$defs/jsonSafeUnsigned" },
            { "type": "null" }
          ]
        },
        "value": { "$ref": "#/$defs/nullableNumber" }
      }
    },
    "waveforms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_count", "sha256", "channels"],
      "properties": {
        "channel_count": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "channels": {
          "type": "array",
          "items": { "$ref": "#/$defs/waveformChannel" }
        }
      }
    },
    "waveformChannel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_id",
        "source_file_kind",
        "unit",
        "sample_rate_hz",
        "sample_count",
        "start_offset_milliseconds",
        "segments",
        "source_sha256",
        "sha256",
        "encoding",
        "head_samples",
        "tail_samples"
      ],
      "properties": {
        "channel_id": { "$ref": "#/$defs/canonicalIdentifier" },
        "source_file_kind": { "$ref": "#/$defs/resmedFileKind" },
        "unit": { "type": "string" },
        "sample_rate_hz": { "type": "number", "exclusiveMinimum": 0 },
        "sample_count": { "$ref": "#/$defs/jsonSafePositive" },
        "start_offset_milliseconds": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/waveformSegment" }
        },
        "source_sha256": { "$ref": "#/$defs/sha256" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "encoding": { "$ref": "#/$defs/waveformEncoding" },
        "head_samples": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "number" }
        },
        "tail_samples": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "type": "number" }
        }
      }
    },
    "waveformSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "start_sample", "sample_count", "start_offset_milliseconds", "source_sha256"],
      "properties": {
        "sequence": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "start_sample": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "sample_count": { "$ref": "#/$defs/jsonSafePositive" },
        "start_offset_milliseconds": { "$ref": "#/$defs/jsonSafeUnsigned" },
        "source_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "waveformEncoding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "digital_min",
        "digital_max",
        "physical_min_decimal",
        "physical_max_decimal",
        "samples_per_record",
        "record_duration_decimal"
      ],
      "properties": {
        "kind": { "const": "edf-i16le-f32be-segments-v1" },
        "digital_min": { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "digital_max": { "type": "integer", "minimum": -32768, "maximum": 32767 },
        "physical_min_decimal": { "$ref": "#/$defs/canonicalEdfDecimal" },
        "physical_max_decimal": { "$ref": "#/$defs/canonicalEdfDecimal" },
        "samples_per_record": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
        "record_duration_decimal": { "$ref": "#/$defs/canonicalPositiveEdfDecimal" }
      }
    }
  }
}
